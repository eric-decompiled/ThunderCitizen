{
  "name": "thundercitizen",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/leaflet": "^1.9.21",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "sass": "^1.83.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "scripts": {
    "css": "sass --style=compressed --quiet-deps --load-path=node_modules static/css/style.scss static/css/style.css",
    "css:watch": "sass --watch --quiet-deps --load-path=node_modules static/css/style.scss static/css/style.css",
    "gen:ts": "go run scripts/gen-ts-types.go",
    "build:js": "npx tsc --noEmit && esbuild web/transit/transit-map.ts --bundle --format=iife --minify --sourcemap --outfile=static/transit/transit-map.js --alias:leaflet=./web/leaflet-shim.cjs",
    "build:js:watch": "esbuild web/transit/transit-map.ts --bundle --format=iife --sourcemap --outfile=static/transit/transit-map.js --alias:leaflet=./web/leaflet-shim.cjs --watch",
    "lint:js": "eslint static/",
    "lint:ts": "eslint web/",
    "lint": "eslint static/ web/"
  },
  "dependencies": {
    "@picocss/pico": "^2.1.1"
  }
}
