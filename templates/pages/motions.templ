package pages

import (
	"fmt"
	"thundercitizen/internal/views"
	"thundercitizen/templates"
	"thundercitizen/templates/components"
)

templ Council(vm views.CouncilViewModel) {
	@templates.Layout(templates.SocialMeta{
		Title:       "Minutes",
		Description: "Every Thunder Bay city council meeting, searchable — motion summaries, recorded votes, and headline decisions from each session.",
		OGImage:     "/static/og/minutes.png",
	}) {
		@components.YearSelector(components.YearSelectorProps{
			Years:     []int{2022},
			Current:   vm.Filter.TermYear,
			BaseURL:   "/minutes",
			ParamName: "term",
			Labels:    map[int]string{2022: "2022–2026"},
			AriaLabel: "Select council term",
		})
		@components.HeroStats(components.HeroStatsProps{
			Title: "Council Meeting Minutes",
			Footer: minutesDisclaimer(),
		}) {
			@components.StatGrid(components.StatGridProps{
				Items: []components.StatItem{
					{Value: vm.Stats.TotalMeetings, Label: "Meetings"},
					{Value: vm.Stats.TotalMotions, Label: "Motions"},
					{Value: vm.Stats.RecordedVotes, Label: "Recorded Votes"},
				},
				Columns: 3,
			})
			<p class="hero-stats-lead">A <strong>recorded vote</strong> happens when a councillor requests a roll call, putting each member's yea or nay on the public record. Most motions pass by voice vote. For full agendas and documents, visit the <a href="https://pub-thunderbay.escribemeetings.com/" target="_blank" rel="noopener">City's eScribe Portal</a>.</p>
		}
		@components.TermPanel(components.TermPanelProps{Title: "Meetings"}) {
			@minutesSearchBar(vm)
			<div id="meetings-content">
				if vm.MotionSearch != nil {
					@MotionSearchResults(*vm.MotionSearch)
				} else {
					@CouncilTablePartial(vm)
				}
			</div>
		}
		@meetingsSwapAnimation()
	}
}

templ minutesDisclaimer() {
	<p class="llm-disclaimer">Summaries are generated with Anthropic AI. Reader discretion is advised.</p>
}

templ meetingsSwapAnimation() {
	<script>
	(function () {
		var target = document.getElementById('meetings-content');
		if (!target) return;

		// CRT phosphor page-turn: flicker out old content, stagger new rows in
		document.body.addEventListener('htmx:beforeSwap', function (e) {
			if (e.detail.target !== target) return;
			var rows = target.querySelectorAll('.meeting-row, .motion-card, .meetings-toolbar');
			rows.forEach(function (el) {
				el.classList.add('meeting-row--fade-out');
			});
		});

		document.body.addEventListener('htmx:afterSwap', function (e) {
			if (e.detail.target !== target) return;
			var rows = target.querySelectorAll('.meeting-row, .motion-card, .meetings-toolbar');
			rows.forEach(function (el, i) {
				el.style.opacity = '0';
				el.classList.add('meeting-row--fade-in');
				el.style.animationDelay = (i * 30) + 'ms';
			});
		});

		// Sync filter chip active state from URL after HTMX pushes
		function syncFilters() {
			var params = new URLSearchParams(window.location.search);
			var chips = document.querySelectorAll('.meeting-filters .filter-chip');
			chips.forEach(function (c) {
				var href = new URL(c.href, window.location.origin);
				var hp = new URLSearchParams(href.search);
				var match = (hp.get('votes') || '') === (params.get('votes') || '');
				c.classList.toggle('active', match);
			});
		}

		document.body.addEventListener('htmx:pushedIntoHistory', syncFilters);
		document.body.addEventListener('htmx:afterSwap', function (e) {
			if (e.detail.target === target) syncFilters();
		});
	})();
	</script>
}

templ minutesSearchBar(vm views.CouncilViewModel) {
	<div class="minutes-search-bar">
		<input
			type="search"
			name="q"
			value={ vm.Filter.Query }
			placeholder="Search motions..."
			aria-label="Search motions"
			hx-get="/minutes"
			hx-target="#meetings-content"
			hx-swap="innerHTML"
			hx-push-url="true"
			hx-trigger="input changed delay:300ms, search"
			hx-include="this"
			hx-indicator="closest .minutes-search-bar"
		/>
		<nav class="meeting-filters" aria-label="Filter meetings">
			<a
				href={ templ.SafeURL(meetingFilterURL(vm, "", "")) }
				class={ "filter-chip", templ.KV("active", !vm.Filter.RecordedVotes) }
				hx-get={ meetingFilterURL(vm, "", "") }
				hx-target="#meetings-content"
				hx-swap="innerHTML"
				hx-push-url="true"
			>All</a>
			<a
				href={ templ.SafeURL(meetingFilterURL(vm, "", "votes")) }
				class={ "filter-chip", templ.KV("active", vm.Filter.RecordedVotes) }
				hx-get={ meetingFilterURL(vm, "", "votes") }
				hx-target="#meetings-content"
				hx-swap="innerHTML"
				hx-push-url="true"
			>Recorded Votes</a>
		</nav>
	</div>
}

// CouncilTablePartial renders table + pagination for HTMX swaps.
// Filter chips live in the combined search bar above (outside the swap target).
templ CouncilTablePartial(vm views.CouncilViewModel) {
	<div class="meetings-controls">
		@meetingsToolbar(vm)
	</div>
	<div class="meetings-list">
		for _, m := range vm.Meetings {
			@meetingRow(m)
		}
	</div>
}

templ meetingsToolbar(vm views.CouncilViewModel) {
	<div class="meetings-toolbar">
		<p class="motions-count">
			{ fmt.Sprintf("%d", vm.Pagination.Total) } meetings
			if vm.Pagination.TotalPages > 1 {
				· page { fmt.Sprintf("%d", vm.Pagination.Page) } of { fmt.Sprintf("%d", vm.Pagination.TotalPages) }
			}
		</p>
		if vm.Pagination.TotalPages > 1 {
			<nav class="pagination-compact" aria-label="Page navigation">
				if vm.Pagination.HasPrev {
					<a
						href={ templ.SafeURL(councilPaginationURL(vm, vm.Pagination.PrevPage)) }
						hx-get={ councilPaginationURL(vm, vm.Pagination.PrevPage) }
						hx-target="#meetings-content"
						hx-swap="innerHTML"
					>&larr; Prev</a>
				} else {
					<span class="pagination-disabled">&larr; Prev</span>
				}
				if vm.Pagination.HasNext {
					<a
						href={ templ.SafeURL(councilPaginationURL(vm, vm.Pagination.NextPage)) }
						hx-get={ councilPaginationURL(vm, vm.Pagination.NextPage) }
						hx-target="#meetings-content"
						hx-swap="innerHTML"
					>Next &rarr;</a>
				} else {
					<span class="pagination-disabled">Next &rarr;</span>
				}
			</nav>
		}
	</div>
}

templ meetingRow(m views.MeetingSummaryView) {
	<div class="meeting-row">
		<h3 class="meeting-row-date">{ m.Date }</h3>
		<p class="meeting-row-summary">{ m.Summary }</p>
		<div class="meeting-row-meta">
			<span class="meeting-row-count">{ fmt.Sprintf("%d motions", m.MotionCount) }</span>
			if m.MediaCount > 0 {
				<span class="badge badge-notable">{ fmt.Sprintf("%d notable", m.MediaCount) }</span>
			}
			if m.RecordedVotes > 0 {
				<span class="badge badge-vote">{ fmt.Sprintf("%d recorded", m.RecordedVotes) }</span>
			}
			if m.LostCount > 0 {
				<span class="badge badge-lost">{ fmt.Sprintf("%d defeated", m.LostCount) }</span>
			}
			if m.MinutesURL != "" {
				<a href={ templ.SafeURL(m.MinutesURL) } class="meeting-row-btn meeting-row-btn-external" target="_blank" rel="noopener">Official Minutes <span class="ext-link-icon" aria-hidden="true"></span></a>
			}
			<a href={ templ.SafeURL(fmt.Sprintf("/minutes/%s", m.Slug)) } class="meeting-row-btn">See Minutes</a>
		</div>
	</div>
}

func councilPaginationURL(vm views.CouncilViewModel, page int) string {
	url := fmt.Sprintf("/minutes?term=%d&page=%d", vm.Filter.TermYear, page)
	if vm.Filter.RecordedVotes {
		url += "&votes=1"
	}
	if vm.Filter.Headline {
		url += "&headline=1"
	}
	if vm.Filter.Notable {
		url += "&notable=1"
	}
	if vm.Filter.Query != "" {
		url += "&q=" + vm.Filter.Query
	}
	return url
}

func meetingFilterURL(vm views.CouncilViewModel, filter1, filter2 string) string {
	url := fmt.Sprintf("/minutes?term=%d", vm.Filter.TermYear)
	if filter1 == "headline" {
		url += "&headline=1"
	}
	if filter2 == "notable" {
		url += "&notable=1"
	}
	if filter2 == "votes" {
		url += "&votes=1"
	}
	return url
}

// MotionSearchResults renders motion search results for HTMX swaps.
templ MotionSearchResults(vm views.MotionSearchViewModel) {
	@motionSearchToolbar(vm)
	if len(vm.Motions) == 0 {
		<p class="no-results">No motions found. Try a different search or broaden your filters.</p>
	} else {
		for _, m := range vm.Motions {
			@motionSearchResult(m)
		}
	}
	@motionSearchToolbar(vm)
}

templ motionSearchToolbar(vm views.MotionSearchViewModel) {
	<div class="meetings-toolbar">
		<p class="motions-count">
			{ fmt.Sprintf("%d", vm.Pagination.Total) } motions
			if vm.RecordedVotes > 0 {
				· { fmt.Sprintf("%d", vm.RecordedVotes) } recorded votes
			}
			if vm.Pagination.TotalPages > 1 {
				· page { fmt.Sprintf("%d", vm.Pagination.Page) } of { fmt.Sprintf("%d", vm.Pagination.TotalPages) }
			}
		</p>
		if vm.Pagination.TotalPages > 1 {
			<nav class="pagination-compact" aria-label="Page navigation">
				if vm.Pagination.HasPrev {
					<a
						href={ templ.SafeURL(motionPaginationURL(vm, vm.Pagination.PrevPage)) }
						hx-get={ motionPaginationURL(vm, vm.Pagination.PrevPage) }
						hx-target="#meetings-content"
						hx-swap="innerHTML"
					>&larr; Prev</a>
				} else {
					<span class="pagination-disabled">&larr; Prev</span>
				}
				if vm.Pagination.HasNext {
					<a
						href={ templ.SafeURL(motionPaginationURL(vm, vm.Pagination.NextPage)) }
						hx-get={ motionPaginationURL(vm, vm.Pagination.NextPage) }
						hx-target="#meetings-content"
						hx-swap="innerHTML"
					>Next &rarr;</a>
				} else {
					<span class="pagination-disabled">Next &rarr;</span>
				}
			</nav>
		}
	</div>
}

templ motionSearchResult(m views.MotionSearchRow) {
	<article class={ "motion-card", templ.KV("motion-lost", m.ResultClass == "lost") }>
		<header>
			<div class="motion-header-row">
				<span class={ "badge", fmt.Sprintf("badge-%s", m.ResultClass) }>{ m.Result }</span>
				if m.Significance == "headline" || m.Significance == "notable" {
					<span class={ "badge", fmt.Sprintf("badge-%s", m.Significance) }>{ m.Significance }</span>
				}
				if m.HasVote {
					<span class="badge badge-vote">{ m.VoteSummary }</span>
				}
				<time class="motion-date">
					<a href={ templ.SafeURL(fmt.Sprintf("/minutes/%s", m.MeetingSlug)) }>{ m.Date }</a>
				</time>
			</div>
			if m.Heading != "" {
				<h3 class="motion-agenda-item">{ m.Heading }</h3>
			}
		</header>
		if m.Summary != "" {
			<p class="motion-summary">{ m.Summary }</p>
		}
		<details>
			<summary>Full motion text</summary>
			if len(m.TextClauses) > 1 {
				<p>{ m.TextClauses[0] }</p>
				<ul class="motion-clauses">
					for _, clause := range m.TextClauses[1:] {
						<li>{ clause }</li>
					}
				</ul>
			} else {
				<p>{ m.Text }</p>
			}
		</details>
		<footer class="motion-meta">
			<small>Moved by { m.MovedBy } · Seconded by { m.SecondedBy }</small>
		</footer>
	</article>
}

func motionPaginationURL(vm views.MotionSearchViewModel, page int) string {
	url := fmt.Sprintf("/minutes?page=%d", page)
	if vm.Filter.Query != "" {
		url += "&q=" + vm.Filter.Query
	}
	if vm.Filter.Term != "" {
		url += fmt.Sprintf("&term=%d", vm.Filter.TermYear)
	}
	if vm.Filter.Significance != "" {
		url += "&significance=" + vm.Filter.Significance
	}
	if vm.Filter.Result != "" {
		url += "&result=" + vm.Filter.Result
	}
	return url
}
