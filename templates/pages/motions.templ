package pages

import (
	"fmt"
	"thundercitizen/internal/views"
	"thundercitizen/templates"
	"thundercitizen/templates/components"
)

templ Council(vm views.CouncilViewModel) {
	@templates.Layout("Minutes") {
		@components.YearSelector(components.YearSelectorProps{
			Years:     []int{2022},
			Current:   vm.Filter.TermYear,
			BaseURL:   "/minutes",
			ParamName: "term",
			Labels:    map[int]string{2022: "2022–2026"},
			AriaLabel: "Select council term",
		})
		@minutesSearch(vm.Filter.Query)
		@components.PageHeader(components.PageHeaderProps{
			Title: "Council Meeting Minutes",
			Lead:  "Browse council meetings and motions from the Thunder Bay City Council.",
		})
		@components.Card(components.CardProps{}) {
			@components.StatGrid(components.StatGridProps{
				Items: []components.StatItem{
					{Value: vm.Stats.TotalMeetings, Label: "Meetings"},
					{Value: vm.Stats.TotalMotions, Label: "Motions"},
					{Value: vm.Stats.RecordedVotes, Label: "Recorded Votes"},
				},
				Columns: 3,
			})
			<p class="stat-explainer">A <strong>recorded vote</strong> happens when a councillor requests a roll call, putting each member's yea or nay on the public record. Most motions pass by voice vote.</p>
				<p class="stat-explainer">For full agendas and documents, visit the <a href="https://pub-thunderbay.escribemeetings.com/" target="_blank" rel="noopener">City's eScribe Portal</a>.</p>
				<p class="llm-disclaimer">Meeting and motion summaries are generated by <strong>Claude</strong> (claude-haiku-4-5-20251001) via the Anthropic API. Each motion's text, agenda item, result, and vote count are provided to the model, which produces a plain-language summary, short label, and significance classification (headline, notable, routine, or procedural). Meeting summaries synthesize all motions from a single session. Summaries may contain errors — always refer to the official minutes for authoritative records.</p>
		}
		<div id="meetings-content">
			if vm.MotionSearch != nil {
				@MotionSearchResults(*vm.MotionSearch)
			} else {
				@CouncilTablePartial(vm)
			}
		</div>
	}
}

templ minutesSearch(query string) {
	<div class="minutes-search-bar">
		<input
			type="search"
			name="q"
			value={ query }
			placeholder="Search motions..."
			aria-label="Search motions"
			hx-get="/minutes"
			hx-target="#meetings-content"
			hx-swap="innerHTML"
			hx-push-url="true"
			hx-trigger="input changed delay:300ms, search"
			hx-include="this"
		/>
	</div>
}

// CouncilTablePartial renders filters + table + pagination for HTMX swaps.
templ CouncilTablePartial(vm views.CouncilViewModel) {
	<nav class="meeting-filters" aria-label="Filter meetings">
		<a
			href={ templ.SafeURL(filterURL(vm, false, false)) }
			class={ "filter-chip", templ.KV("active", !vm.Filter.RecordedVotes && !vm.Filter.Defeated) }
			hx-get={ filterURL(vm, false, false) }
			hx-target="#meetings-content"
			hx-swap="innerHTML"
			hx-push-url="true"
		>All</a>
		<a
			href={ templ.SafeURL(filterURL(vm, true, false)) }
			class={ "filter-chip", templ.KV("active", vm.Filter.RecordedVotes) }
			hx-get={ filterURL(vm, true, false) }
			hx-target="#meetings-content"
			hx-swap="innerHTML"
			hx-push-url="true"
		>Recorded Votes</a>
		<a
			href={ templ.SafeURL(filterURL(vm, false, true)) }
			class={ "filter-chip", templ.KV("active", vm.Filter.Defeated) }
			hx-get={ filterURL(vm, false, true) }
			hx-target="#meetings-content"
			hx-swap="innerHTML"
			hx-push-url="true"
		>Defeated Motions</a>
	</nav>
	<div class="meetings-controls">
		@meetingsToolbar(vm)
	</div>
	<div class="meetings-list">
		for _, m := range vm.Meetings {
			@meetingRow(m)
		}
	</div>
}

templ meetingsToolbar(vm views.CouncilViewModel) {
	<div class="meetings-toolbar">
		<p class="motions-count">
			{ fmt.Sprintf("%d", vm.Pagination.Total) } meetings
			if vm.Pagination.TotalPages > 1 {
				· page { fmt.Sprintf("%d", vm.Pagination.Page) } of { fmt.Sprintf("%d", vm.Pagination.TotalPages) }
			}
		</p>
		if vm.Pagination.TotalPages > 1 {
			<nav class="pagination-compact" aria-label="Page navigation">
				if vm.Pagination.HasPrev {
					<a
						href={ templ.SafeURL(councilPaginationURL(vm, vm.Pagination.PrevPage)) }
						hx-get={ councilPaginationURL(vm, vm.Pagination.PrevPage) }
						hx-target="#meetings-content"
						hx-swap="innerHTML"
					>&larr; Prev</a>
				} else {
					<span class="pagination-disabled">&larr; Prev</span>
				}
				if vm.Pagination.HasNext {
					<a
						href={ templ.SafeURL(councilPaginationURL(vm, vm.Pagination.NextPage)) }
						hx-get={ councilPaginationURL(vm, vm.Pagination.NextPage) }
						hx-target="#meetings-content"
						hx-swap="innerHTML"
					>Next &rarr;</a>
				} else {
					<span class="pagination-disabled">Next &rarr;</span>
				}
			</nav>
		}
	</div>
}

templ meetingRow(m views.MeetingSummaryView) {
	<div class="meeting-row">
		<p class="meeting-row-summary">{ m.Summary }</p>
		<div class="meeting-row-meta">
			<span class="meeting-row-date">{ m.Date }</span>
			<span class="meeting-row-count">{ fmt.Sprintf("%d motions", m.MotionCount) }</span>
			if m.HeadlineCount > 0 {
				<span class="badge badge-headline">{ fmt.Sprintf("%d headline", m.HeadlineCount) }</span>
			}
			if m.NotableCount > 0 {
				<span class="badge badge-notable">{ fmt.Sprintf("%d notable", m.NotableCount) }</span>
			}
			if m.RecordedVotes > 0 {
				<span class="badge badge-vote">{ fmt.Sprintf("%d recorded", m.RecordedVotes) }</span>
			}
			if m.LostCount > 0 {
				<span class="badge badge-lost">{ fmt.Sprintf("%d defeated", m.LostCount) }</span>
			}
			<a href={ templ.SafeURL(fmt.Sprintf("/minutes/%s", m.ID)) } class="meeting-row-btn">See Minutes</a>
			if m.MinutesURL != "" {
				<a href={ templ.SafeURL(m.MinutesURL) } class="meeting-row-btn meeting-row-btn-external" target="_blank" rel="noopener">Official Minutes ↗</a>
			}
		</div>
	</div>
}

func councilPaginationURL(vm views.CouncilViewModel, page int) string {
	url := fmt.Sprintf("/minutes?term=%d&page=%d", vm.Filter.TermYear, page)
	if vm.Filter.RecordedVotes {
		url += "&votes=1"
	}
	if vm.Filter.Defeated {
		url += "&defeated=1"
	}
	if vm.Filter.Query != "" {
		url += "&q=" + vm.Filter.Query
	}
	return url
}

func filterURL(vm views.CouncilViewModel, votes, defeated bool) string {
	url := fmt.Sprintf("/minutes?term=%d", vm.Filter.TermYear)
	if votes {
		url += "&votes=1"
	}
	if defeated {
		url += "&defeated=1"
	}
	return url
}

// MotionSearchResults renders motion search results for HTMX swaps.
templ MotionSearchResults(vm views.MotionSearchViewModel) {
	@motionSearchToolbar(vm)
	if len(vm.Motions) == 0 {
		<p class="no-results">No motions found. Try a different search or broaden your filters.</p>
	} else {
		for _, m := range vm.Motions {
			@motionSearchResult(m)
		}
	}
	@motionSearchToolbar(vm)
}

templ motionSearchToolbar(vm views.MotionSearchViewModel) {
	<div class="meetings-toolbar">
		<p class="motions-count">
			{ fmt.Sprintf("%d", vm.Pagination.Total) } motions
			if vm.RecordedVotes > 0 {
				· { fmt.Sprintf("%d", vm.RecordedVotes) } recorded votes
			}
			if vm.Pagination.TotalPages > 1 {
				· page { fmt.Sprintf("%d", vm.Pagination.Page) } of { fmt.Sprintf("%d", vm.Pagination.TotalPages) }
			}
		</p>
		if vm.Pagination.TotalPages > 1 {
			<nav class="pagination-compact" aria-label="Page navigation">
				if vm.Pagination.HasPrev {
					<a
						href={ templ.SafeURL(motionPaginationURL(vm, vm.Pagination.PrevPage)) }
						hx-get={ motionPaginationURL(vm, vm.Pagination.PrevPage) }
						hx-target="#meetings-content"
						hx-swap="innerHTML"
					>&larr; Prev</a>
				} else {
					<span class="pagination-disabled">&larr; Prev</span>
				}
				if vm.Pagination.HasNext {
					<a
						href={ templ.SafeURL(motionPaginationURL(vm, vm.Pagination.NextPage)) }
						hx-get={ motionPaginationURL(vm, vm.Pagination.NextPage) }
						hx-target="#meetings-content"
						hx-swap="innerHTML"
					>Next &rarr;</a>
				} else {
					<span class="pagination-disabled">Next &rarr;</span>
				}
			</nav>
		}
	</div>
}

templ motionSearchResult(m views.MotionSearchRow) {
	<article class={ "motion-card", templ.KV("motion-lost", m.ResultClass == "lost") }>
		<header>
			<div class="motion-header-row">
				<span class={ "badge", fmt.Sprintf("badge-%s", m.ResultClass) }>{ m.Result }</span>
				if m.Significance == "headline" || m.Significance == "notable" {
					<span class={ "badge", fmt.Sprintf("badge-%s", m.Significance) }>{ m.Significance }</span>
				}
				if m.HasVote {
					<span class="badge badge-vote">{ m.VoteSummary }</span>
				}
				<time class="motion-date">
					<a href={ templ.SafeURL(fmt.Sprintf("/minutes/%s", m.MeetingID)) }>{ m.Date }</a>
				</time>
			</div>
			if m.AgendaItem != "" {
				<h3 class="motion-agenda-item">{ m.AgendaItem }</h3>
			}
		</header>
		if m.Summary != "" {
			<p class="motion-summary">{ m.Summary }</p>
		}
		<details>
			<summary>Full motion text</summary>
			if len(m.TextClauses) > 1 {
				<p>{ m.TextClauses[0] }</p>
				<ul class="motion-clauses">
					for _, clause := range m.TextClauses[1:] {
						<li>{ clause }</li>
					}
				</ul>
			} else {
				<p>{ m.Text }</p>
			}
		</details>
		<footer class="motion-meta">
			<small>Moved by <a href={ templ.SafeURL("/councillors/" + views.CouncillorSlug(m.MovedBy)) }>{ m.MovedBy }</a> · Seconded by <a href={ templ.SafeURL("/councillors/" + views.CouncillorSlug(m.SecondedBy)) }>{ m.SecondedBy }</a></small>
		</footer>
	</article>
}

func motionPaginationURL(vm views.MotionSearchViewModel, page int) string {
	url := fmt.Sprintf("/minutes?page=%d", page)
	if vm.Filter.Query != "" {
		url += "&q=" + vm.Filter.Query
	}
	if vm.Filter.Term != "" {
		url += fmt.Sprintf("&term=%d", vm.Filter.TermYear)
	}
	if vm.Filter.Significance != "" {
		url += "&significance=" + vm.Filter.Significance
	}
	if vm.Filter.Result != "" {
		url += "&result=" + vm.Filter.Result
	}
	return url
}
