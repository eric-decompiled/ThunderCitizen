# ThunderCitizen secrets — copy to secrets.conf and fill in values.
# secrets.conf is .gitignored and never committed.
#
# Env vars override these values, so you can still do:
#   DATABASE_URL=postgres://... make dev
#
# In containers, mount or attach secrets.conf:
#   podman run -v ./secrets.conf:/app/secrets.conf:ro ...
#   podman run --secret tc-secrets -e SECRETS_FILE=/run/secrets/tc-secrets ...

DATABASE_URL=postgres://postgres:postgres@localhost:5432/thundercitizen?sslmode=disable

# Only needed for `go run ./cmd/summarize` (LLM motion classification)
# ANTHROPIC_API_KEY=sk-ant-...
